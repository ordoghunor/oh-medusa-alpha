{
  "branches": ["main"],
  "tagFormat": "storefront-${version}",
  "plugins": [
    [
      "@semantic-release/commit-analyzer",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/release-notes-generator",
      {
        "preset": "conventionalcommits"
      }
    ],
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.storefront.md"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.storefront.md"],
        "message": "chore(release): storefront ${nextRelease.version} [skip ci]\\n\\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
